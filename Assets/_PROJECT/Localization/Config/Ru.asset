  <StaticTranslates>k__BackingField: []
  TaskTranslates:
  - <Id>k__BackingField: 0
    _text: "\u041F\u043E\u043F\u0430\u0434\u0438 \u0432\u043E \u0432\u0440\u0430\u0433\u0430
      {0} \u0440\u0430\u0437"
  - <Id>k__BackingField: 1
    _text: "\u0412\u044B\u0438\u0433\u0440\u0430\u0439 {0} \u0440\u0430\u0437"
  - <Id>k__BackingField: 2
    _text: "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439 \u0430\u043F\u0442\u0435\u0447\u043A\u0443
      {0} \u0440\u0430\u0437"
  - <Id>k__BackingField: 3
    _text: "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439 \u0449\u0438\u0442
      {0} \u0440\u0430\u0437"
  - <Id>k__BackingField: 4
    _text: "\u0418\u0437\u043B\u0435\u0447\u0438 {0} \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F"
  - <Id>k__BackingField: 5
    _text: "\u041F\u0440\u043E\u0439\u0434\u0438 \u043F\u0430\u0440\u043A\u0443\u0440"
  TutorialTranslates:
  - <Id>k__BackingField: 0
    _text: "\u0417\u0430\u0436\u043C\u0438 \u043F\u0430\u043B\u0435\u0446 \u0432
      \u044D\u0442\u043E\u0439 \u0437\u043E\u043D\u0435 \u0438 \u0434\u0432\u0438\u0433\u0430\u0439
      \u0438\u043C - \u043D\u0430\u0432\u0435\u0434\u0438\u0441\u044C \u043D\u0430
      \u0432\u0440\u0430\u0433\u0430"
  - <Id>k__BackingField: 1
    _text: "\u0428\u043A\u0430\u043B\u0430 \u0441\u0438\u043B\u044B = \u0434\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
      \u0431\u0440\u043E\u0441\u043A\u0430. \u0427\u0435\u043C \u0431\u043E\u043B\u044C\u0448\u0435
      \u0437\u0430\u0440\u044F\u0434\u0438\u0448\u044C - \u0442\u0435\u043C \u0434\u0430\u043B\u044C\u0448\u0435
      \u043B\u0435\u0442\u0438\u0442"
  - <Id>k__BackingField: 2
    _text: "\u041E\u0442\u043F\u0443\u0441\u0442\u0438 \u043F\u0430\u043B\u0435\u0446
      - \u0438 \u0441\u043D\u0430\u0440\u044F\u0434 \u043F\u043E\u043B\u0435\u0442\u0438\u0442
      \u043F\u0440\u044F\u043C\u043E \u0432 \u0446\u0435\u043B\u044C"
  - <Id>k__BackingField: 3
    _text: "\u041F\u043E\u043F\u043E\u043B\u043D\u0438 \u0441\u0432\u043E\u0435 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435,
      \u043D\u0430\u0436\u043C\u0438 \u043D\u0430 \u0430\u043F\u0442\u0435\u0447\u043A\u0443"
  - <Id>k__BackingField: 4
    _text: "\u041D\u0430\u0436\u043C\u0438 \u043D\u0430 \xAB\u0412\u0437\u0440\u044B\u0432\xBB
      \u043F\u0435\u0440\u0435\u0434 \u0431\u0440\u043E\u0441\u043A\u043E\u043C -
      \u0443\u0440\u043E\u043D \u0441\u0442\u0430\u043D\u0435\u0442 \u043C\u043E\u0449\u043D\u0435\u0435"
